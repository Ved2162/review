# =============================================================================
# Magic Review — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# On Lovable Cloud these are managed for you and injected automatically.
# Only fill these in manually when self-hosting.
# =============================================================================

# ---- Lovable Cloud / Supabase (publishable — safe in client bundle) ----------
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-publishable-anon-key>"
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# ---- Server-only mirrors (used by createServerFn handlers) -------------------
# Same values as above; kept under non-VITE names so they're never accidentally
# bundled into the browser.
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<your-publishable-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# ---- OpenAI API key (server-only — NEVER commit a real value) ------------
# Set your ChatGPT/OpenAI API key here and in deployment env vars.
# OPENAI_API_KEY="sk..."
